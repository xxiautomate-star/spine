# Supabase — persistence for waitlist, memories, api_keys.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI — used server-side for cloud-mode memory embeddings (1536 dim).
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic — used by /api/recall for Haiku 4.5 relevance reranking.
# Optional: if unset, recall falls back to fused RRF + decay scoring.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — used in OG metadata when set.
NEXT_PUBLIC_SITE_URL=https://spine.xxiautomate.com

# Schema lives in supabase/schema.sql — apply with:
#   psql "$DATABASE_URL" -f supabase/schema.sql
# or paste into the Supabase SQL editor.
