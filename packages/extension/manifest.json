{
  "manifest_version": 3,
  "name": "Spine — Memory for your AI",
  "short_name": "Spine",
  "version": "0.2.0",
  "description": "Captures conversations from Claude, ChatGPT, Gemini, v0, and Cursor automatically. Your AI finally knows you — across every session.",
  "minimum_chrome_version": "116",
  "permissions": ["storage", "activeTab", "alarms", "scripting"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://v0.dev/*",
    "https://cursor.sh/*",
    "https://codeium.com/*",
    "https://windsurf.codeium.com/*",
    "https://spine.xxiautomate.com/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content-claude.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["content-chatgpt.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content-gemini.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://v0.dev/*"],
      "js": ["content-v0.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://cursor.sh/*"],
      "js": ["content-cursor.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://codeium.com/*", "https://windsurf.codeium.com/*"],
      "js": ["content-codeium.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://v0.dev/*",
        "https://cursor.sh/*",
        "https://codeium.com/*",
        "https://windsurf.codeium.com/*"
      ],
      "js": ["content-hygiene.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Spine — memories captured this session",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
