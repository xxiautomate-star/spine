{
  "name": "@spine/extension-harness",
  "version": "0.0.0",
  "private": true,
  "description": "Playwright harness that loads the Spine extension and drives ChatGPT/Gemini. Scaffold only — tests skip unless SPINE_EXT_HARNESS=1.",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "install-browsers": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/chrome": "^0.0.287",
    "@types/node": "^20.17.17",
    "vitest": "^2.1.0"
  }
}
